page {
  background-color: #FDF6F0;
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

.container {
  padding: 0;
  min-height: 100vh;
}

/* 通用样式 */
.coffee-primary { color: #6B4226; }
.coffee-bg { background: #6B4226; }

.btn-primary {
  background: linear-gradient(135deg, #6B4226, #C4956A);
  color: #fff;
  border-radius: 50rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 40rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.btn-primary::after { border: none; }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #ccc;
}

.empty-icon { font-size: 100rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 26rpx; }
