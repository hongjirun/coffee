.index-page {
  min-height: 100vh;
  background: #FDF6F0;
  display: flex;
  flex-direction: column;
}

.banner {
  background: linear-gradient(135deg, #4a2c0a 0%, #6b4226 60%, #c4956a 100%);
  padding: 40rpx 30rpx 30rpx;
  position: relative;
}

.shop-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.guide-btn {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255,255,255,0.25);
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.5);
}

.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #4a2c0a;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  z-index: 99;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.15);
}
.cart-bar-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.cart-bar-icon {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cart-bar-emoji {
  font-size: 32rpx;
}
.cart-bar-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  background: #e74c3c;
  color: #fff;
  font-size: 18rpx;
  min-width: 30rpx;
  height: 30rpx;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}
.cart-bar-text {
  font-size: 26rpx;
  color: #fff;
}
.cart-bar-text.empty {
  color: rgba(255,255,255,0.5);
}
.cart-bar-btn {
  background: #c4956a;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 16rpx 36rpx;
  border-radius: 50rpx;
}

.content-area {
  flex: 1;
  display: flex;
  height: calc(100vh - 220rpx);
  padding-bottom: 110rpx;
}

.category-list {
  width: 190rpx;
  background: #f0e6da;
  flex-shrink: 0;
}

.category-item {
  padding: 32rpx 20rpx;
  font-size: 26rpx;
  color: #666;
  text-align: center;
  line-height: 1.4;
  border-left: 4rpx solid transparent;
  transition: all 0.2s;
}

.category-item.active {
  background: #FDF6F0;
  color: #6B4226;
  font-weight: 600;
  border-left-color: #6B4226;
}

.product-list {
  flex: 1;
  padding: 16rpx;
}

.product-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  display: flex;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(107, 66, 38, 0.08);
  padding: 16rpx;
  gap: 16rpx;
  align-items: flex-start;
}

.product-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  object-fit: cover;
  flex-shrink: 0;
}

.product-img-empty {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f5e6d3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 140rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.product-desc {
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.product-price {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
  color: #6B4226;
}

.price-symbol { font-size: 22rpx; font-weight: 600; }
.price-num { font-size: 36rpx; font-weight: 700; }
.price-up { font-size: 20rpx; color: #999; }

.add-btn {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #6b4226, #c4956a);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 40rpx;
  font-weight: 300;
  box-shadow: 0 4rpx 12rpx rgba(107, 66, 38, 0.3);
}

.loading-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  color: #999;
  font-size: 26rpx;
}

.loading-icon {
  font-size: 80rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 12rpx;
  color: #999;
}
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 26rpx; }

/* ===== 遮罩 ===== */
.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

/* ===== 底部弹出面板 ===== */
.panel {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.panel-show {
  transform: translateY(0);
}

.panel-header {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid #f5e6d3;
}

.panel-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.panel-img-empty {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: #f5e6d3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.panel-product-text {
  flex: 1;
}

.panel-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.panel-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #6b4226;
}

.panel-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
  line-height: 1;
}

/* ===== 选项区 ===== */
.panel-scroll {
  flex: 1;
  padding: 0 24rpx 24rpx;
  max-height: 55vh;
  box-sizing: border-box;
}

.opt-section {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f9f0e8;
}

.opt-section:last-child { border-bottom: none; }

.opt-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.opt-optional {
  font-size: 20rpx;
  color: #c4956a;
  font-weight: normal;
  margin-left: 8rpx;
}

.opt-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.opt-tag {
  padding: 12rpx 24rpx;
  border: 2rpx solid #e8d5c4;
  border-radius: 50rpx;
  background: #fdf6f0;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.opt-tag.selected {
  border-color: #6b4226;
  background: #6b4226;
}

.opt-tag.selected .tag-name { color: #fff; }
.opt-tag.selected .tag-price { color: rgba(255,255,255,0.8); }

.tag-name { font-size: 26rpx; color: #555; }
.tag-price { font-size: 20rpx; color: #c4956a; }

.quantity-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-direction: row;
}

.qty-ctrl {
  display: flex;
  align-items: center;
  background: #f5e6d3;
  border-radius: 50rpx;
  padding: 6rpx;
}

.qty-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #6b4226;
  font-weight: 500;
  line-height: 1;
}

.qty-btn.disabled { background: #f0f0f0; color: #ccc; }

.qty-num {
  width: 80rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #6b4226;
}

/* ===== 地址表单 ===== */
.order-form {
  padding: 20rpx 24rpx;
  flex: 1;
}

.form-tips {
  font-size: 24rpx;
  color: #c4956a;
  background: #fdf6f0;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5e6d3;
}

.form-row.align-start { align-items: flex-start; padding-top: 20rpx; }

.form-label {
  font-size: 26rpx;
  color: #666;
  width: 90rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  text-align: right;
}

.form-textarea {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  min-height: 80rpx;
  line-height: 1.6;
}

.addr-pick-row { cursor: pointer; }

.addr-pick-btn {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
  justify-content: flex-end;
}

.addr-pick-icon { font-size: 28rpx; }

.addr-pick-text {
  font-size: 26rpx;
  color: #6b4226;
}

.addr-pick-arrow {
  font-size: 30rpx;
  color: #c4956a;
}

.addr-chosen {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.addr-chosen-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.addr-chosen-detail {
  font-size: 22rpx;
  color: #888;
  text-align: right;
  line-height: 1.4;
}

.addr-reselect {
  font-size: 22rpx;
  color: #6b4226;
}

/* ===== 订单摘要 ===== */
.order-summary {
  padding: 20rpx 24rpx;
  flex: 1;
}

.summary-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.summary-card {
  background: #fdf6f0;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}

.summary-line {
  font-size: 26rpx;
  color: #555;
  line-height: 2;
}

.summary-tip {
  font-size: 24rpx;
  color: #c4956a;
  text-align: center;
  line-height: 1.6;
}

/* ===== 面板底部按钮 ===== */
.panel-footer {
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f5e6d3;
}

.btn-full {
  background: linear-gradient(135deg, #6b4226, #c4956a);
  color: #fff;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 50rpx;
  letter-spacing: 2rpx;
}

.btn-row {
  display: flex;
  gap: 16rpx;
}

.btn-copy {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border: 2rpx solid #6b4226;
  color: #6b4226;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #fff;
}

.btn-share {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #6b4226, #c4956a);
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  margin: 0;
}

/* ===== 审核模式：咖啡科普页样式 ===== */
.rv-page {
  min-height: 100vh;
  background: #1a0f00;
  display: flex;
  flex-direction: column;
}
.rv-hero {
  background: linear-gradient(160deg, #1a0f00 0%, #3d1f00 50%, #6b3a00 100%);
  padding: 80rpx 40rpx 60rpx;
  text-align: center;
}
.rv-hero-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.rv-hero-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #f5c97a;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}
.rv-hero-sub {
  font-size: 26rpx;
  color: rgba(245,201,122,0.6);
  letter-spacing: 2rpx;
}
.rv-scroll {
  flex: 1;
  padding: 30rpx;
  height: calc(100vh - 280rpx);
}
.rv-card {
  background: rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(245,201,122,0.15);
}
.rv-card-tag {
  display: inline-block;
  background: rgba(245,201,122,0.2);
  color: #f5c97a;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 14rpx;
  letter-spacing: 2rpx;
}
.rv-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 16rpx;
}
.rv-card-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
  line-height: 1.8;
  margin-bottom: 16rpx;
}
.rv-card-arrow {
  font-size: 22rpx;
  color: #f5c97a;
  text-align: right;
  opacity: 0.8;
}

.remark-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 16rpx 24rpx;
}
.remark-input {
  width: 100%;
  height: 72rpx;
  background: #f5f0eb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
}

.product-images-row {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
}
.product-img-item {
  flex: 1;
  background: #f9f2ec;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.product-img-thumb {
  width: 100%;
  height: 260rpx;
}
.product-img-label {
  font-size: 22rpx;
  color: #999;
  padding: 10rpx 0;
}
