.cart-page {
  min-height: 100vh;
  background: #FDF6F0;
  padding-bottom: 160rpx;
}

/* 空状态 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  gap: 16rpx;
}

.empty-icon { font-size: 120rpx; }
.empty-title { font-size: 32rpx; font-weight: 600; color: #333; }
.empty-sub { font-size: 26rpx; color: #999; }

.go-order-btn {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #6b4226, #c4956a);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-weight: 600;
}

/* 商品列表 */
.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx 12rpx;
}

.cart-title { font-size: 30rpx; font-weight: 600; color: #333; }
.clear-btn { font-size: 26rpx; color: #999; }

.cart-list {
  padding: 0 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.cart-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  position: relative;
}

.item-img-wrap {
  width: 110rpx;
  height: 110rpx;
  border-radius: 10rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #f5e6d3;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-img { width: 100%; height: 100%; }
.item-img-empty { font-size: 50rpx; }

.item-detail { flex: 1; }

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.item-opts {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-bottom: 12rpx;
}

.item-opts text {
  font-size: 22rpx;
  color: #6b4226;
  background: #f5e6d3;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
}

.item-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-price {
  font-size: 26rpx;
  color: #6b4226;
  font-weight: 600;
}

.qty-controls {
  display: flex;
  align-items: center;
  gap: 0;
}

.qty-btn-sm {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #f0e6da;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #6b4226;
  font-weight: 600;
}

.qty-btn-sm.plus {
  background: #6b4226;
  color: #fff;
}

.qty-val {
  width: 60rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.remove-btn {
  position: absolute;
  top: 12rpx;
  right: 16rpx;
  font-size: 36rpx;
  color: #ccc;
  line-height: 1;
  padding: 4rpx;
}

/* 订单信息表单 */
.order-form {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.form-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5e6d3;
}

.form-item:last-child { border-bottom: none; }

.remark-item { align-items: flex-start; padding-top: 20rpx; }

.form-label {
  font-size: 26rpx;
  color: #666;
  width: 100rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  text-align: right;
}

.form-textarea {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  min-height: 100rpx;
  line-height: 1.5;
}

/* 结算栏 */
.checkout-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -4rpx 20rpx rgba(107, 66, 38, 0.1);
}

.checkout-total {
  display: flex;
  flex-direction: column;
}

.total-label { font-size: 22rpx; color: #999; }
.total-amount { font-size: 44rpx; font-weight: 700; color: #6b4226; }

.checkout-btn {
  background: linear-gradient(135deg, #6b4226, #c4956a);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0 60rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 50rpx;
  letter-spacing: 2rpx;
}

.checkout-btn.loading {
  opacity: 0.7;
}
