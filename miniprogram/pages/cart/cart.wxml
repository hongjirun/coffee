<view class="cart-page">

  <!-- 订单完成：复制/转发到群 -->
  <view class="order-done" wx:if="{{orderDone && orderSummary}}">
    <view class="done-icon">✅</view>
    <view class="done-title">订单已生成！</view>
    <view class="done-tip">复制下方订单发到群里，完成付款即可</view>
    <view class="summary-card">
      <view class="summary-line" wx:for="{{orderSummary.lines}}" wx:key="*this">{{item}}</view>
    </view>
    <view class="privacy-tip">🔒 收件人及地址已加密，转发到群后仅商家后台可见，群成员无法查看您的个人信息</view>
    <view class="done-btns">
      <view class="btn-copy" bindtap="onCopyOrder">📋 复制订单</view>
      <button class="btn-share" open-type="share">📤 转发到群</button>
    </view>
    <view class="btn-back" bindtap="goHome">继续点单</view>
  </view>

  <!-- 空购物车 -->
  <view class="empty-cart" wx:if="{{cart.length === 0 && !orderDone && !submitting}}">
    <text class="empty-icon">🛒</text>
    <text class="empty-title">购物车是空的</text>
    <text class="empty-sub">去点一杯属于你的咖啡吧</text>
    <view class="go-order-btn" bindtap="goOrder">去点单</view>
  </view>

  <!-- 有商品 -->
  <block wx:if="{{cart.length > 0 && !orderDone}}">
    <!-- 商品列表 -->
    <view class="cart-header">
      <text class="cart-title">已选商品</text>
      <text class="clear-btn" bindtap="clearCart">清空</text>
    </view>

    <view class="cart-list">
      <view class="cart-item" wx:for="{{cart}}" wx:key="_key">
        <view class="item-img-wrap">
          <image class="item-img" src="{{item.product_image}}" mode="aspectFill" wx:if="{{item.product_image}}" />
          <view class="item-img-empty" wx:else>☕</view>
        </view>

        <view class="item-detail">
          <view class="item-name">{{item.product_name}}</view>
          <view class="item-opts">
            <text wx:if="{{item.size}}">{{item.size.name || item.size}}</text>
            <text wx:if="{{item.sugar}}">{{item.sugar}}</text>
            <text wx:if="{{item.ice}}">{{item.ice}}</text>
            <text wx:for="{{item.addons}}" wx:key="name" wx:for-item="addon">+{{addon.name}}</text>
          </view>
          <view class="item-price-row">
            <text class="item-price">¥{{item.unit_price}}/杯</text>
            <view class="qty-controls">
              <view class="qty-btn-sm" data-index="{{index}}" data-type="minus" bindtap="onQuantityChange">−</view>
              <text class="qty-val">{{item.quantity}}</text>
              <view class="qty-btn-sm plus" data-index="{{index}}" data-type="plus" bindtap="onQuantityChange">+</view>
            </view>
          </view>
        </view>

        <view class="remove-btn" data-index="{{index}}" bindtap="onRemoveItem">×</view>
      </view>
    </view>

    <!-- 收货信息 -->
    <view class="order-form">
      <view class="form-tips">📝 填写收货信息后即可生成订单发到群里</view>
      <view class="form-item">
        <text class="form-label">姓名</text>
        <input
          class="form-input"
          value="{{customerName}}"
          placeholder="您的称呼"
          bindinput="onNameInput"
        />
      </view>
      <view class="form-item addr-pick-row" bindtap="onChooseAddress">
        <text class="form-label">地址</text>
        <view class="addr-pick-btn" wx:if="{{!chosenAddress}}">
          <text class="addr-pick-icon">📍</text>
          <text class="addr-pick-text">点击选择微信地址</text>
          <text class="addr-pick-arrow">›</text>
        </view>
        <view class="addr-chosen" wx:else>
          <text class="addr-chosen-name">{{chosenAddress.userName}} {{chosenAddress.telNumber}}</text>
          <text class="addr-chosen-detail">{{chosenAddress.provinceName}}{{chosenAddress.cityName}}{{chosenAddress.countyName}}{{chosenAddress.detailInfo}}</text>
          <text class="addr-reselect">重选 ›</text>
        </view>
      </view>
      <view class="form-item">
        <text class="form-label">备注</text>
        <input
          class="form-input"
          value="{{remark}}"
          placeholder="楼栋/单元/房号/备注（选填）"
          bindinput="onRemarkInput"
        />
      </view>
    </view>

    <!-- 底部结算栏 -->
    <view class="checkout-bar">
      <view class="checkout-total">
        <text class="total-label">合计</text>
        <text class="total-amount">¥{{totalPrice}}</text>
      </view>
      <view
        class="checkout-btn {{submitting ? 'loading' : ''}}"
        bindtap="submitOrder"
      >
        {{submitting ? '提交中...' : '提交订单'}}
      </view>
    </view>
  </block>
</view>
