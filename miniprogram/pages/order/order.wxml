<view class="order-page">

  <!-- 订单详情模式 -->
  <block wx:if="{{mode === 'detail'}}">
    <view wx:if="{{loading}}" class="loading-wrap">
      <text class="loading-text">加载中...</text>
    </view>
    <view wx:elif="{{order}}" class="detail-wrap">
      <!-- 状态栏 -->
      <view class="detail-status-bar status-bg-{{order.status}}">
        <text class="detail-status-icon">{{order.status === 'pending' ? '⏳' : order.status === 'preparing' ? '☕' : order.status === 'completed' ? '✅' : '❌'}}</text>
        <text class="detail-status-text">{{order.status_text}}</text>
      </view>

      <!-- 基本信息 -->
      <view class="detail-card">
        <view class="detail-row">
          <text class="detail-label">订单号</text>
          <text class="detail-value mono">{{order.order_no}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">下单时间</text>
          <text class="detail-value">{{order.created_at}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">收件人</text>
          <text class="detail-value bold">{{shared ? '******' : order.customer_name}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">备注/地址</text>
          <text class="detail-value">{{shared ? '******' : order.remark}}</text>
        </view>
      </view>

      <!-- 商品明细 -->
      <view class="detail-card">
        <view class="detail-section-title">☕ 商品明细</view>
        <view class="item-row" wx:for="{{order.items}}" wx:key="id">
          <view class="item-name-row">
            <text class="item-name">{{item.product_name}}</text>
            <text class="item-qty">×{{item.quantity}}</text>
          </view>
          <view class="item-opts">
            <text wx:if="{{item.size}}">[杯型: {{item.size}}] </text>
            <text wx:if="{{item.ice}}">[温度: {{item.ice}}] </text>
            <text wx:if="{{item.sugar}}">[糖度: {{item.sugar}}] </text>
            <text wx:if="{{item.addons_text !== '无'}}">[加料: {{item.addons_text}}]</text>
          </view>
          <view class="item-price">小计: ¥{{item.subtotal}}</view>
        </view>
      </view>

      <!-- 总价 -->
      <view class="detail-total">
        <text>合计金额</text>
        <text class="total-val">¥{{order.total_amount}}</text>
      </view>

      <!-- 分享按钮 -->
      <view wx:if="{{!shared}}">
        <button class="share-btn" bindtap="toggleShare">📤 转发订单</button>
      </view>
      <view wx:else class="share-action-row">
        <button class="share-btn share-btn-cancel" bindtap="toggleShare">取消</button>
        <button class="share-btn share-btn-confirm" open-type="share">确认转发</button>
      </view>
    </view>
  </block>

  <!-- 订单列表模式 -->
  <block wx:elif="{{mode === 'list'}}">
    <view class="empty-state" wx:if="{{orders.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-title">暂无订单记录</text>
      <text class="empty-sub">快去点一杯美味的咖啡吧</text>
      <view class="go-btn" bindtap="goHome">去点单</view>
    </view>
    <view class="order-list" wx:else>
      <view class="order-card" wx:for="{{orders}}" wx:key="order_no">
        <view class="order-card-header">
          <text class="order-no">订单号：{{item.order_no}}</text>
          <text class="order-status status-{{item.status}}">{{item.status_text}}</text>
        </view>
        <view class="order-time">{{item.created_at}}</view>
        <view class="order-amount">合计：<text class="amount-val">¥{{item.total_amount}}</text></view>
      </view>
    </view>
  </block>

</view>
