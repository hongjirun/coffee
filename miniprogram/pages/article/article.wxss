.art-page {
  min-height: 100vh;
  background: #1a0f00;
  display: flex;
  flex-direction: column;
}
.art-hero {
  background: linear-gradient(160deg, #1a0f00 0%, #3d1f00 50%, #6b3a00 100%);
  padding: 60rpx 40rpx 50rpx;
}
.art-tag {
  display: inline-block;
  background: rgba(245,201,122,0.2);
  color: #f5c97a;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}
.art-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.4;
}
.art-scroll {
  flex: 1;
  height: calc(100vh - 240rpx);
}
.art-body {
  padding: 40rpx 36rpx 60rpx;
}
.art-paragraph {
  font-size: 28rpx;
  color: rgba(255,255,255,0.75);
  line-height: 2;
  margin-bottom: 32rpx;
  text-align: justify;
}
