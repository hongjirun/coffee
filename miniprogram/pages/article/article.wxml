<view class="art-page">
  <view class="art-hero">
    <view class="art-tag">{{article.tag}}</view>
    <view class="art-title">{{article.title}}</view>
  </view>
  <scroll-view scroll-y class="art-scroll">
    <view class="art-body">
      <view class="art-paragraph" wx:for="{{article.paragraphs}}" wx:key="index">{{item}}</view>
    </view>
  </scroll-view>
</view>
