.guide-page {
  min-height: 100vh;
  background: #FDF6F0;
  padding: 30rpx 30rpx 60rpx;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 30rpx;
  gap: 12rpx;
}

.hero-icon { font-size: 100rpx; }

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.hero-sub {
  font-size: 26rpx;
  color: #999;
}

.steps {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-bottom: 30rpx;
}

.step-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(107, 66, 38, 0.08);
}

.step-num {
  font-size: 48rpx;
  font-weight: 900;
  color: #e8d5c4;
  line-height: 1;
  flex-shrink: 0;
  width: 80rpx;
}

.step-body {
  flex: 1;
}

.step-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 10rpx;
}

.step-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
}

.step-emoji {
  font-size: 48rpx;
  flex-shrink: 0;
}

.step-arrow {
  text-align: center;
  font-size: 36rpx;
  color: #c4956a;
  padding: 8rpx 0;
}

.notice-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 16rpx rgba(107, 66, 38, 0.08);
}

.notice-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.notice-item {
  font-size: 24rpx;
  color: #777;
  line-height: 2;
}

.go-btn {
  background: linear-gradient(135deg, #6b4226, #c4956a);
  color: #fff;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 50rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(107, 66, 38, 0.3);
}

/* 二维码区域 */
.qrcode-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 16rpx rgba(107, 66, 38, 0.08);
}

.qrcode-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
}

.qrcode-list {
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
}

.qrcode-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.qrcode-img {
  width: 240rpx;
  height: 240rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.qrcode-text {
  font-size: 24rpx;
  color: #666;
}

.qrcode-tip {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  margin-top: 20rpx;
}
