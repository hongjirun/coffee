.product-page {
  background: #FDF6F0;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.product-hero {
  width: 100%;
  height: 480rpx;
  overflow: hidden;
}

.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-empty {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #f5e6d3, #c4956a);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-icon { font-size: 120rpx; }

.product-body {
  padding: 24rpx;
}

.product-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.product-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
}

.product-price {
  display: flex;
  align-items: baseline;
  color: #6B4226;
  flex-shrink: 0;
}

.price-symbol { font-size: 24rpx; font-weight: 600; }
.price-num { font-size: 48rpx; font-weight: 700; }
.price-tip { font-size: 22rpx; color: #999; margin-left: 4rpx; }

.product-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.option-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.option-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.option-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.option-required {
  font-size: 20rpx;
  color: #fff;
  background: #ff4757;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
}

.option-optional {
  font-size: 20rpx;
  color: #fff;
  background: #c4956a;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
}

.option-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-tag {
  padding: 12rpx 24rpx;
  border: 2rpx solid #e8d5c4;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #fdf6f0;
  transition: all 0.15s;
  position: relative;
}

/* 点击时的反馈效果 */
.option-tag:active {
  transform: scale(0.95);
  background: #f5e6d8;
  box-shadow: 0 4rpx 12rpx rgba(107, 66, 38, 0.2);
}

/* 选中状态 - 更明显的视觉反馈 */
.option-tag.selected {
  border-color: #6B4226;
  border-width: 3rpx;
  background: #6B4226;
  box-shadow: 0 4rpx 16rpx rgba(107, 66, 38, 0.35);
  transform: scale(1.02);
}

/* 选中状态的勾选标记 */
.option-tag.selected::after {
  content: '✓';
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 28rpx;
  height: 28rpx;
  background: #fff;
  color: #6B4226;
  border-radius: 50%;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.option-tag.selected .tag-name,
.option-tag.selected .tag-price {
  color: #fff;
}

.tag-name {
  font-size: 26rpx;
  color: #555;
}

.tag-price {
  font-size: 22rpx;
  color: #c4956a;
}

.quantity-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.quantity-ctrl {
  display: flex;
  align-items: center;
  gap: 0;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f5e6d3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #6B4226;
  font-weight: 600;
}

.qty-btn.disabled {
  background: #f0f0f0;
  color: #ccc;
}

.qty-num {
  width: 80rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -4rpx 20rpx rgba(107, 66, 38, 0.1);
}

.total-info {
  display: flex;
  flex-direction: column;
}

.total-label {
  font-size: 22rpx;
  color: #999;
}

.total-price {
  font-size: 44rpx;
  font-weight: 700;
  color: #6B4226;
}

.add-cart-btn {
  background: linear-gradient(135deg, #6b4226, #c4956a);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0 60rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 50rpx;
  letter-spacing: 2rpx;
}

.product-images-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.product-img-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.product-img-thumb {
  width: 100%;
  height: 280rpx;
}

.product-img-label {
  font-size: 22rpx;
  color: #999;
  padding: 10rpx 0;
}

.loading-page {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  color: #999;
  font-size: 28rpx;
}
